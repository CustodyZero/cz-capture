# Environment variables for local development.
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# Name of the DynamoDB table (matches TableName in infra/template.yaml)
WAITLIST_TABLE=cz-capture-waitlist

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://custodyzero.com,https://www.custodyzero.com

# Set to "development" locally to enable localhost CORS and no-origin requests.
# Never set "development" in production.
NODE_ENV=development
